generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String
  passwordChangedAt   DateTime  @default(now())
  mustChangePassword  Boolean   @default(false)
  tokenVersion        Int       @default(0)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  auditLogs    AdminAuditLog[]
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id @default(cuid())
  adminId   String
  jti       String    @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  category  String
  action    String
  metadata  String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([category])
  @@index([createdAt])
}

model PasswordResetOtp {
  id           String   @id @default(cuid())
  email        String
  otp          String
  resetToken   String   @unique @default(cuid())
  attemptCount Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  resource  String?
  metadata  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model GalleryImage {
  id           String   @id @default(cuid())
  title        String
  description  String?
  imageUrl     String
  cloudinaryId String
  category     String
  featured     Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([featured])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  priceUSD    Float?
  priceNGN    Float?
  priceNote   String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model BookingRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  service   String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model SiteSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Invoice {
  id                 String   @id @default(cuid())
  invoiceNumber      String   @unique
  clientName         String
  clientAddress      String?
  currency           String   @default("NGN")
  items              String
  notes              String?
  reference          String?
  dueDate            DateTime
  status             String   @default("unpaid")
  // JSON array of PaymentAccount IDs selected for this invoice.
  // Empty/null = show all active accounts matching currency.
  paymentAccountIds  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model PaymentAccount {
  id            String   @id @default(cuid())
  label         String
  // Type: "bank" | "paypal" | "wise" | "other"
  type          String   @default("bank")
  currency      String
  // Bank-specific fields (required for type=bank, nullable for others)
  bankName      String?
  accountName   String?
  accountNumber String?
  swiftCode     String?
  iban          String?
  sortCode      String?
  // Email-based fields (PayPal, Wise)
  email         String?
  // Generic fields
  notes         String?
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([currency])
  @@index([active])
  @@index([order])
  @@index([type])
}

model Subscriber {
  id                    String    @id @default(cuid())
  email                 String    @unique
  status                String    @default("pending")
  confirmToken          String?   @unique
  confirmTokenExpiresAt DateTime?
  unsubscribeToken      String    @unique
  confirmedAt           DateTime?
  unsubscribedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([email])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Broadcast {
  id          String    @id @default(cuid())
  subject     String
  html        String
  text        String?
  sentAt      DateTime?
  sentCount   Int       @default(0)
  failedCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sentAt])
  @@index([createdAt])
}


